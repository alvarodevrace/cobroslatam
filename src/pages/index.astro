---
import Layout from '../components/Layout.astro';

const herramientas = [
  {
    slug: 'calculadora-comisiones',
    titulo: 'Calculadora de Comisiones',
    desc: 'Calcula cuanto pierdes por fees en PayPal, Wise, Stripe y Payoneer.',
    emoji: '💸',
  },
  {
    slug: 'calculadora-neto-objetivo',
    titulo: 'Calculadora Neto Objetivo',
    desc: 'Descubre cuanto debes cobrar para recibir exactamente lo que necesitas.',
    emoji: '🎯',
  },
  {
    slug: 'comparador-plataformas',
    titulo: 'Comparador de Plataformas',
    desc: 'Compara fees, tipo de cambio y limites de PayPal, Wise, Stripe y Payoneer.',
    emoji: '⚖️',
  },
  {
    slug: 'calculadora-precio-freelance',
    titulo: 'Calculadora Precio Freelance',
    desc: 'Calcula tu tarifa hora o mensual incluyendo impuestos y margen.',
    emoji: '🧮',
  },
  {
    slug: 'generador-cotizacion',
    titulo: 'Generador de Cotizacion',
    desc: 'Genera una propuesta de precio lista para copiar y enviar a tu cliente.',
    emoji: '📄',
  },
];
---
<Layout
  title="CobrosLatAm 2026 | Herramientas para cobrar del exterior"
  description="Calculadoras gratuitas para freelancers de LatAm: comisiones, neto objetivo, comparativa de plataformas y mas."
>
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold text-white mb-4">
      Cobra mejor desde <span class="text-emerald-400">LatAm</span>
    </h1>
    <p class="text-zinc-400 text-lg max-w-2xl mx-auto">
      Herramientas gratuitas para freelancers: calcula comisiones, compara plataformas y optimiza cada cobro en USD.
    </p>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mt-8">
    {herramientas.map(h => (
      <a
        href={`/herramientas/${h.slug}`}
        class="group rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 hover:border-emerald-500/50 hover:bg-zinc-900 transition-all"
      >
        <div class="text-3xl mb-3">{h.emoji}</div>
        <h2 class="text-lg font-semibold text-white group-hover:text-emerald-400 transition-colors mb-2">
          {h.titulo}
        </h2>
        <p class="text-sm text-zinc-400">{h.desc}</p>
      </a>
    ))}
  </section>
</Layout>
